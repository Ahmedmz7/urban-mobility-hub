# Urban Mobility Hub — Environment Variables
# Copy this file to .env and fill in your own API keys.
# NEVER commit the .env file to version control.

# TfL Unified API (no key required for basic endpoints — optional for higher rate limits)
# Register at: https://api-portal.tfl.gov.uk/
VITE_TFL_APP_KEY=

# OpenRouteService API key (free tier available)
# Register at: https://openrouteservice.org/dev/#/login
VITE_ORS_API_KEY=
